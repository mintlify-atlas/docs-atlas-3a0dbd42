  "keyFeatures": [
    "Model Context Protocol (MCP) server implementation",
    "Multi-database support (PostgreSQL, MySQL, MariaDB, SQL Server, SQLite)",
    "Token-efficient schema exploration with progressive disclosure",
    "Multi-connection TOML configuration",
    "SSH tunneling and SSL/TLS encryption",
    "Built-in web workbench interface",
    "Read-only mode and query guardrails",
    "Custom tool definitions for reusable SQL operations"
  ],
  "publicApiSurface": [
    "execute_sql - Execute SQL queries with transaction support",
    "search_objects - Search database schemas, tables, columns, indexes, procedures",
    "Custom tools - User-defined parameterized SQL operations",
    "Connector interface - Extend with new database types",
    "ConnectorRegistry - Dynamic connector registration",
    "ConnectorManager - Multi-database connection management",
    "Transport modes - stdio (desktop) and HTTP (network clients)",
    "CLI options - --dsn, --transport, --config, --readonly, --demo"
  ]
